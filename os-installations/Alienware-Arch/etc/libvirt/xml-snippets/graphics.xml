<graphics type="spice">
    <listen type="socket" socket="/tmp/vm_spice.sock"/>
    <image compression="off"/>
    <jpeg compression="never"/>
    <zlib compression="never"/>
    <playback compression="off"/>

    <!-- Use the iGPU for hardware video acceleration -->
    <!-- When not using PCI passthrough, you can select your dGPU instead, -->
    <!-- but don't forget to remove the dGPU from the hardware list! -->
    <gl enable="yes" rendernode="/dev/dri/by-path/pci-0000:00:02.0-render"/>
</graphics>
