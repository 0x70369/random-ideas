# Static information about the filesystems.
# See fstab(5) for details.

# Custom /tmp entry
# WARNING: instead of defining an entry here, edit the *tmp.mount* systemd unit with the options listed here
tmpfs   /tmp    tmpfs   rw,nr_inodes=1m,size=69%,nodev,nosuid,mode=1777,relatime,x-systemd.graceful-option=usrquota,huge=within_size   0   0

# tmpfs folder for storing non-essential files (like downloads). Usable by regular (non-admin) users and root
## https://wiki.archlinux.org/title/Tmpfs#Examples
tmpfs	/temp	tmpfs	rw,nr_inodes=10k,size=69%,nodev,nosuid,gid=users,mode=1770,relatime,x-systemd.automount,x-systemd.graceful-option=usrquota,huge=within_size	0	0

# tmpfs folders to speed up the system
## https://wiki.archlinux.org/title/Improving_performance#Relocate_files_to_tmpfs
## ~/.cache
tmpfs	/home/youruser/.cache	tmpfs	rw,nr_inodes=100k,size=5%,nodev,nosuid,uid=youruser,mode=1700,relatime,huge=within_size	0	0
